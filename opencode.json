{
  "$schema": "https://opencode.ai/config.json",
  "autoupdate": true,
  "permission": {
    "bash": {
      "*": "ask",
      "gh *": "allow",
      "git *": "allow"
    },
    "edit": "allow",
    "read": "allow",
    "grep": "allow",
    "glob": "allow",
    "lsp": "allow",
    "skill": "allow",
    "todowrite": "allow",
    "webfetch": "ask",
    "websearch": "ask",
    "question": "allow"
  },
  "mcp": {
    "brilliant": {
      "type": "remote",
      "url": "http://127.0.0.1:3333/mcp",
      "enabled": true
    }
  }
}
